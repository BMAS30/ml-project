    "    'MTRANS': ['Walking', 'Bike', 'Public_Transportation', 'Motorbike', 'Automobile']\n",
    "}\n",
    "\n",
    "# OrdinalEncoder for ordinal columns\n",
    "ordinal_encoder = OrdinalEncoder(categories=[ord_mapping[col] for col in categorical_ordinal_vars])\n",
    "\n",
    "# OneHotEncoder for nominal columns\n",
    "onehot_encoder = OneHotEncoder(drop='first', sparse_output=False)\n",
    "\n",
    "# ColumnTransformer to combine\n",
    "preprocessor = ColumnTransformer(\n",
    "    transformers=[\n",
    "        ('num', 'passthrough', numerical_vars),\n",
    "        ('ord', ordinal_encoder, categorical_ordinal_vars),\n",
    "        ('nom', onehot_encoder, categorical_nominal_vars)\n",
    "    ]\n",
    ")\n",
    "\n",
    "# Separate data from target\n",
    "X = df.drop(columns=[target_col])\n",
