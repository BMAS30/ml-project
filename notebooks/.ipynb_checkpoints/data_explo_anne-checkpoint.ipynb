    "# Target\n",
    "target_col = 'NObeyesdad'\n",
    "\n",
    "# Ordinal categories\n",
    "ord_mapping = {\n",
    "    'CAEC': ['no', 'Sometimes', 'Frequently', 'Always'],\n",
    "    'CALC': ['no', 'Sometimes', 'Frequently', 'Always'],\n",
    "    'family_history_with_overweight': ['no', 'yes'],\n",
